# Core runtime
PORT=8484
SESSION_COOKIE_NAME=tw_session
SESSION_TTL_HOURS=12
COOKIE_SECURE=0

# Database
# Leave DB_PATH unset for local default db/tomwood.db,
# or set an absolute production path such as:
# DB_PATH=/srv/tomwood-workshop/data/tomwood.db
# DB_PATH=

# Optional Google auth backend settings.
# Note: the current shipped UI is in demo mode and does not enforce login.
# These are only useful if app-level login is re-enabled later.
# GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
# GOOGLE_HOSTED_DOMAIN=tomwood.no
